generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id           String   @id @default(cuid())
  externalId   String   @unique
  name         String
  city         String
  abbreviation String   @unique
  conference   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  awayGames    Game[]   @relation("AwayTeam")
  homeGames    Game[]   @relation("HomeTeam")
  players      Player[]
}

model Player {
  id            String        @id @default(cuid())
  externalId    String        @unique
  firstName     String
  lastName      String
  position      Position
  jersey        Int?
  active        Boolean       @default(true)
  teamId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  draftPicks    DraftPick[]
  team          Team?         @relation(fields: [teamId], references: [id])
  rosterEntries RosterEntry[]
  statLines     StatLine[]

  @@index([teamId])
  @@index([lastName, firstName])
}

model Game {
  id         String     @id @default(cuid())
  externalId String     @unique
  season     String
  startsAt   DateTime
  status     GameStatus @default(SCHEDULED)
  homeTeamId String
  awayTeamId String
  homeScore  Int?
  awayScore  Int?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  awayTeam   Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam   Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  statLines  StatLine[]

  @@index([season, startsAt])
  @@index([status])
}

model StatLine {
  id             String   @id @default(cuid())
  playerId       String
  gameId         String
  goals          Int      @default(0)
  assists        Int      @default(0)
  shots          Int      @default(0)
  plusMinus      Int      @default(0)
  penaltyMinutes Int      @default(0)
  powerPlayPts   Int      @default(0)
  hits           Int      @default(0)
  blocks         Int      @default(0)
  saves          Int      @default(0)
  goalsAgainst   Int      @default(0)
  shutout        Boolean  @default(false)
  win            Boolean  @default(false)
  timeOnIceSecs  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  game           Game     @relation(fields: [gameId], references: [id])
  player         Player   @relation(fields: [playerId], references: [id])

  @@unique([playerId, gameId])
  @@index([gameId])
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  displayName  String
  passwordHash String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  ownedLeagues FantasyLeague[] @relation("Commissioner")
  memberships  FantasyTeam[]
}

model FantasyLeague {
  id              String              @id @default(cuid())
  name            String
  season          String              @default("2026-27")
  draftType       DraftType           @default(SNAKE)
  status          FantasyLeagueStatus @default(PRE_DRAFT)
  maxTeams        Int                 @default(10)
  commissionerId  String
  scoringSettings Json                @default("{}")
  rosterSettings  Json                @default("{}")
  playoffSettings Json                @default("{\"teamsInPlayoff\": 6, \"topSeedsWithBye\": 2, \"higherSeedWinsTies\": true, \"roundDurationPeriods\": 2}")
  playoffStatus   PlayoffStatus       @default(NOT_STARTED)
  draftStartsAt   DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  draft           Draft?
  commissioner    User                @relation("Commissioner", fields: [commissionerId], references: [id])
  teams           FantasyTeam[]
  matchups        Matchup[]
  leagueEvents    LeagueEvent[]

  @@index([status])
}

model FantasyTeam {
  id           String        @id @default(cuid())
  name         String
  leagueId     String
  ownerId      String
  draftOrder   Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  draftPicks   DraftPick[]
  league       FantasyLeague @relation(fields: [leagueId], references: [id])
  owner        User          @relation(fields: [ownerId], references: [id])
  awayMatchups Matchup[]     @relation("AwayFantasyTeam")
  homeMatchups Matchup[]     @relation("HomeFantasyTeam")
  roster       RosterEntry[]

  @@unique([leagueId, ownerId])
  @@index([leagueId])
}

model RosterEntry {
  id            String      @id @default(cuid())
  fantasyTeamId String
  playerId      String
  slot          LineupSlot  @default(BENCH)
  acquired      DateTime    @default(now())
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  player        Player      @relation(fields: [playerId], references: [id])

  @@unique([fantasyTeamId, playerId])
  @@index([fantasyTeamId])
}

model Draft {
  id                String        @id @default(cuid())
  leagueId          String        @unique
  status            DraftStatus   @default(PENDING)
  pickTimerSecs     Int           @default(30)
  currentPick       Int           @default(1)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  autoPickTimerSecs Int           @default(10)
  league            FantasyLeague @relation(fields: [leagueId], references: [id])
  picks             DraftPick[]
}

model DraftPick {
  id            String      @id @default(cuid())
  draftId       String
  overall       Int
  round         Int
  fantasyTeamId String
  playerId      String?
  pickedAt      DateTime?
  auto          Boolean     @default(false)
  draft         Draft       @relation(fields: [draftId], references: [id])
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  player        Player?     @relation(fields: [playerId], references: [id])

  @@unique([draftId, overall])
  @@index([draftId])
}

model Matchup {
  id         String        @id @default(cuid())
  leagueId   String
  week       Int
  startsAt   DateTime
  endsAt     DateTime
  homeTeamId String
  awayTeamId String
  homeScore  Float?
  awayScore  Float?
  isPlayoff  Boolean       @default(false)
  round      Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  awayTeam   FantasyTeam   @relation("AwayFantasyTeam", fields: [awayTeamId], references: [id])
  homeTeam   FantasyTeam   @relation("HomeFantasyTeam", fields: [homeTeamId], references: [id])
  league     FantasyLeague @relation(fields: [leagueId], references: [id])

  @@index([leagueId, week])
}

enum Position {
  FORWARD
  DEFENSE
  GOALIE
}

enum GameStatus {
  SCHEDULED
  LIVE
  FINAL
  POSTPONED
}

enum DraftType {
  SNAKE
  AUCTION
}

enum PlayoffStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum FantasyLeagueStatus {
  PRE_DRAFT
  DRAFTING
  IN_SEASON
  COMPLETE
}

enum LineupSlot {
  FORWARD
  DEFENSE
  GOALIE
  UTIL
  BENCH
  IR
}

enum DraftStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETE
}

enum EventType {
  DRAFT_PICK
  PLAYER_ADD
  PLAYER_DROP
  TRADE
  PLAYOFF_QUALIFICATION
  MAJOR_PERFORMANCE
}

model LeagueEvent {
  id        String        @id @default(cuid())
  leagueId  String
  teamId    String?
  playerId  String?
  type      EventType
  data      Json          @default("{}")
  createdAt DateTime      @default(now())
  league    FantasyLeague @relation(fields: [leagueId], references: [id])

  @@index([leagueId, createdAt])
}
