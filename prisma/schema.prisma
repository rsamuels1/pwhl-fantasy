// PWHL Fantasy — initial database schema
// Provider: PostgreSQL. ORM: Prisma.
//
// Design notes:
// - "League data" (teams, players, games, stat lines) is mirrored FROM the PWHL.
//   It is read-only as far as your app's users are concerned and is refreshed by
//   an ingestion job. Keep it cleanly separated from "fantasy" tables.
// - "Fantasy data" (fantasy leagues, rosters, drafts, matchups) is user-owned.
// - Stat lines are stored raw (per player, per real game). Fantasy points are
//   COMPUTED from raw stats against a league's scoring settings, never stored as
//   the source of truth — so you can change scoring rules and recompute.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// LEAGUE DATA (mirrored from PWHL — refreshed by ingestion job)
// ============================================================

model Team {
  id           String   @id @default(cuid())
  // Stable external id from your stats source, so re-imports are idempotent.
  externalId   String   @unique
  name         String // e.g. "Minnesota Frost"
  city         String
  abbreviation String   @unique // e.g. "MIN"
  conference   String? // null until/if the league defines them for 12 teams
  active       Boolean  @default(true) // false for folded/relocated franchises

  players   Player[]
  homeGames Game[]   @relation("HomeTeam")
  awayGames Game[]   @relation("AwayTeam")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Position {
  FORWARD
  DEFENSE
  GOALIE
}

model Player {
  id         String   @id @default(cuid())
  externalId String   @unique // stable id from stats source
  firstName  String
  lastName   String
  position   Position
  jersey     Int?
  active     Boolean  @default(true) // false if released / not on a 26-27 roster

  // Current team. Nullable: free agents during the open signing period have no team.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  statLines      StatLine[]
  rosterEntries  RosterEntry[]
  draftPicks     DraftPick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([lastName, firstName])
}

model Game {
  id         String     @id @default(cuid())
  externalId String     @unique
  season     String // e.g. "2026-27"
  startsAt   DateTime
  status     GameStatus @default(SCHEDULED)

  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore Int?
  awayScore Int?

  statLines StatLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([season, startsAt])
  @@index([status])
}

enum GameStatus {
  SCHEDULED
  LIVE
  FINAL
  POSTPONED
}

// One row per player per real game. The atomic unit of scoring.
model StatLine {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id])
  gameId   String
  game     Game   @relation(fields: [gameId], references: [id])

  // Skater stats
  goals          Int @default(0)
  assists        Int @default(0)
  shots          Int @default(0)
  plusMinus      Int @default(0)
  penaltyMinutes Int @default(0)
  powerPlayPts   Int @default(0)
  hits           Int @default(0)
  blocks         Int @default(0)

  // Goalie stats
  saves          Int  @default(0)
  goalsAgainst   Int  @default(0)
  shutout        Boolean @default(false)
  win            Boolean @default(false)
  timeOnIceSecs  Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A player can only have one stat line per game.
  @@unique([playerId, gameId])
  @@index([gameId])
}

// ============================================================
// FANTASY DATA (user-owned)
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  // Store a password HASH only if you roll your own auth; prefer an auth provider.
  passwordHash String?

  memberships    FantasyTeam[]
  ownedLeagues   FantasyLeague[] @relation("Commissioner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FantasyLeague {
  id            String              @id @default(cuid())
  name          String
  season        String              @default("2026-27")
  draftType     DraftType           @default(SNAKE)
  status        FantasyLeagueStatus @default(PRE_DRAFT)
  maxTeams      Int                 @default(10)

  commissionerId String
  commissioner   User   @relation("Commissioner", fields: [commissionerId], references: [id])

  // Scoring rules live as JSON so each league can customize without a migration.
  // Validate the shape in application code (see lib/scoring).
  scoringSettings Json @default("{}")
  rosterSettings  Json @default("{}") // slots per position, bench size, etc.

  teams    FantasyTeam[]
  draft    Draft?
  matchups Matchup[]

  draftStartsAt DateTime? // ~ a week before the real season opener
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

enum DraftType {
  SNAKE
  AUCTION
}

enum FantasyLeagueStatus {
  PRE_DRAFT
  DRAFTING
  IN_SEASON
  COMPLETE
}

model FantasyTeam {
  id      String @id @default(cuid())
  name    String

  leagueId String
  league   FantasyLeague @relation(fields: [leagueId], references: [id])
  ownerId  String
  owner    User          @relation(fields: [ownerId], references: [id])

  draftOrder Int? // slot in the draft (1..maxTeams)

  roster       RosterEntry[]
  draftPicks   DraftPick[]
  homeMatchups Matchup[]     @relation("HomeFantasyTeam")
  awayMatchups Matchup[]     @relation("AwayFantasyTeam")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One team per user per league.
  @@unique([leagueId, ownerId])
  @@index([leagueId])
}

// A player currently rostered by a fantasy team, plus their lineup slot.
model RosterEntry {
  id            String  @id @default(cuid())
  fantasyTeamId String
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id])

  slot     LineupSlot @default(BENCH)
  acquired DateTime   @default(now())

  // A player can't be on two slots at once on the same team.
  @@unique([fantasyTeamId, playerId])
  @@index([fantasyTeamId])
}

enum LineupSlot {
  FORWARD
  DEFENSE
  GOALIE
  UTIL
  BENCH
  IR
}

// ============================================================
// DRAFT
// ============================================================

model Draft {
  id        String      @id @default(cuid())
  leagueId  String      @unique
  league    FantasyLeague @relation(fields: [leagueId], references: [id])
  status    DraftStatus @default(PENDING)
  // Seconds each manager has to pick before auto-pick.
  pickTimerSecs Int     @default(90)
  currentPick   Int     @default(1) // overall pick number, 1-based

  picks DraftPick[]

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum DraftStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETE
}

model DraftPick {
  id      String @id @default(cuid())
  draftId String
  draft   Draft  @relation(fields: [draftId], references: [id])

  overall Int // 1-based overall pick number
  round   Int
  // Which fantasy team is on the clock / made the pick.
  fantasyTeamId String
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])

  // Null until the pick is made (lets you pre-seed the full pick board).
  playerId String?
  player   Player?  @relation(fields: [playerId], references: [id])
  pickedAt DateTime?

  @@unique([draftId, overall])
  @@index([draftId])
}

// ============================================================
// MATCHUPS / SCORING PERIODS
// ============================================================

model Matchup {
  id       String @id @default(cuid())
  leagueId String
  league   FantasyLeague @relation(fields: [leagueId], references: [id])

  week      Int
  startsAt  DateTime
  endsAt    DateTime

  homeTeamId String
  homeTeam   FantasyTeam @relation("HomeFantasyTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   FantasyTeam @relation("AwayFantasyTeam", fields: [awayTeamId], references: [id])

  // Final computed scores, cached after a period closes. Recompute from StatLines
  // if scoring settings change retroactively.
  homeScore Float?
  awayScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leagueId, week])
}
