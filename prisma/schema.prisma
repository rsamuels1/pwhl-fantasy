generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id           String   @id @default(cuid())
  externalId   String   @unique
  name         String
  city         String
  abbreviation String   @unique
  conference   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  awayGames    Game[]   @relation("AwayTeam")
  homeGames    Game[]   @relation("HomeTeam")
  players      Player[]
}

model Player {
  id            String        @id @default(cuid())
  externalId    String        @unique
  firstName     String
  lastName      String
  position      Position
  jersey        Int?
  active        Boolean       @default(true)
  teamId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  draftPicks    DraftPick[]
  team          Team?         @relation(fields: [teamId], references: [id])
  rosterEntries RosterEntry[]
  statLines     StatLine[]
  waiverEntries WaiverEntry[]

  @@index([teamId])
  @@index([lastName, firstName])
}

model Game {
  id         String     @id @default(cuid())
  externalId String     @unique
  season     String
  startsAt   DateTime
  status     GameStatus @default(SCHEDULED)
  homeTeamId String
  awayTeamId String
  homeScore  Int?
  awayScore  Int?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  awayTeam   Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam   Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  statLines  StatLine[]

  @@index([season, startsAt])
  @@index([status])
}

model StatLine {
  id             String   @id @default(cuid())
  playerId       String
  gameId         String
  goals          Int      @default(0)
  assists        Int      @default(0)
  shots          Int      @default(0)
  plusMinus      Int      @default(0)
  penaltyMinutes Int      @default(0)
  powerPlayPts   Int      @default(0)
  hits           Int      @default(0)
  blocks         Int      @default(0)
  saves          Int      @default(0)
  goalsAgainst   Int      @default(0)
  shutout        Boolean  @default(false)
  win            Boolean  @default(false)
  timeOnIceSecs  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  game           Game     @relation(fields: [gameId], references: [id])
  player         Player   @relation(fields: [playerId], references: [id])

  @@unique([playerId, gameId])
  @@index([gameId])
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  displayName             String
  passwordHash            String?
  onboardingCompletedAt   DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  ownedLeagues            FantasyLeague[]          @relation("Commissioner")
  memberships             FantasyTeam[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  feedbackSubmissions     FeedbackSubmission[]
}

model FantasyLeague {
  id                      String                   @id @default(cuid())
  name                    String
  season                  String                   @default("2026-27")
  draftType               DraftType                @default(SNAKE)
  status                  FantasyLeagueStatus      @default(PRE_DRAFT)
  maxTeams                Int                      @default(8)
  commissionerId          String
  scoringSettings         Json                     @default("{}")
  rosterSettings          Json                     @default("{}")
  playoffSettings         Json                     @default("{\"teamsInPlayoff\": 4, \"topSeedsWithBye\": 0, \"higherSeedWinsTies\": true, \"roundDurationPeriods\": 2}")
  playoffStatus           PlayoffStatus            @default(NOT_STARTED)
  betaStatus              BetaStatus               @default(NONE)
  announcement            String?
  draftStartsAt           DateTime?
  isReplay                Boolean                  @default(false)
  replayCurrentDate       DateTime?
  scoringMode             String                   @default("VP")
  parentLeagueId          String?
  rulesVersion            Int                      @default(1)
  scoringVersion          Int                      @default(1)
  pwhlPlayoffStartsAt     DateTime?
  waiverWindowHours       Int                      @default(48)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  draft                   Draft?
  commissioner            User                     @relation("Commissioner", fields: [commissionerId], references: [id])
  teams                   FantasyTeam[]
  matchups                Matchup[]
  leagueEvents            LeagueEvent[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  parentLeague            FantasyLeague?           @relation("LeagueLineage", fields: [parentLeagueId], references: [id])
  childLeagues            FantasyLeague[]          @relation("LeagueLineage")
  feedbackSubmissions     FeedbackSubmission[]
  waiverEntries           WaiverEntry[]
  waiverClaims            WaiverClaim[]
  waiverPriority          WaiverPriority[]

  @@index([status])
}

model FantasyTeam {
  id           String        @id @default(cuid())
  name         String
  leagueId     String
  ownerId      String
  draftOrder   Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  draftPicks      DraftPick[]
  league          FantasyLeague  @relation(fields: [leagueId], references: [id])
  owner           User           @relation(fields: [ownerId], references: [id])
  awayMatchups    Matchup[]      @relation("AwayFantasyTeam")
  homeMatchups    Matchup[]      @relation("HomeFantasyTeam")
  roster          RosterEntry[]
  waiverClaims    WaiverClaim[]
  waiverPriority  WaiverPriority[]

  @@unique([leagueId, ownerId])
  @@index([leagueId])
}

model RosterEntry {
  id            String      @id @default(cuid())
  fantasyTeamId String
  playerId      String
  slot          LineupSlot  @default(BENCH)
  acquired      DateTime    @default(now())
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  player        Player      @relation(fields: [playerId], references: [id])

  @@unique([fantasyTeamId, playerId])
  @@index([fantasyTeamId])
}

model Draft {
  id                String        @id @default(cuid())
  leagueId          String        @unique
  status            DraftStatus   @default(PENDING)
  pickTimerSecs     Int           @default(30)
  currentPick       Int           @default(1)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  autoPickTimerSecs Int           @default(10)
  queueData         Json?
  league            FantasyLeague @relation(fields: [leagueId], references: [id])
  picks             DraftPick[]
}

model DraftPick {
  id            String      @id @default(cuid())
  draftId       String
  overall       Int
  round         Int
  fantasyTeamId String
  playerId      String?
  pickedAt      DateTime?
  auto          Boolean     @default(false)
  draft         Draft       @relation(fields: [draftId], references: [id])
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  player        Player?     @relation(fields: [playerId], references: [id])

  @@unique([draftId, overall])
  @@index([draftId])
}

model Matchup {
  id         String        @id @default(cuid())
  leagueId   String
  week       Int
  startsAt   DateTime
  endsAt     DateTime
  homeTeamId String
  awayTeamId String
  homeScore  Float?
  awayScore  Float?
  homeVP     Int?
  awayVP     Int?
  isPlayoff  Boolean       @default(false)
  round      Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  awayTeam   FantasyTeam   @relation("AwayFantasyTeam", fields: [awayTeamId], references: [id])
  homeTeam   FantasyTeam   @relation("HomeFantasyTeam", fields: [homeTeamId], references: [id])
  league     FantasyLeague @relation(fields: [leagueId], references: [id])

  @@index([leagueId, week])
}

model LeagueEvent {
  id        String        @id @default(cuid())
  leagueId  String
  teamId    String?
  playerId  String?
  type      EventType
  data      Json          @default("{}")
  createdAt DateTime      @default(now())
  league    FantasyLeague @relation(fields: [leagueId], references: [id])

  @@index([leagueId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  leagueId  String?
  teamId    String?
  type      NotificationType
  title     String
  body      String?
  actionUrl String?
  dedupeKey String?
  data      Json             @default("{}")
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  league    FantasyLeague?   @relation(fields: [leagueId], references: [id])

  @@unique([userId, type, dedupeKey])
  @@index([userId, leagueId, readAt])
  @@index([leagueId])
}

model NotificationPreference {
  id       String           @id @default(cuid())
  userId   String
  leagueId String
  type     NotificationType
  enabled  Boolean          @default(true)
  user     User             @relation(fields: [userId], references: [id])
  league   FantasyLeague    @relation(fields: [leagueId], references: [id])

  @@unique([userId, leagueId, type])
  @@index([userId])
}

enum Position {
  FORWARD
  DEFENSE
  GOALIE
}

enum GameStatus {
  SCHEDULED
  LIVE
  FINAL
  POSTPONED
}

enum DraftType {
  SNAKE
  AUCTION
}

enum PlayoffStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum FantasyLeagueStatus {
  PRE_DRAFT
  DRAFTING
  IN_SEASON
  COMPLETE
}

enum LineupSlot {
  FORWARD
  DEFENSE
  GOALIE
  UTIL
  BENCH
  IR
}

enum DraftStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETE
}

enum NotificationType {
  DRAFT_STARTING
  ON_THE_CLOCK
  LINEUP_INCOMPLETE
}

model FeedbackSubmission {
  id          String         @id @default(cuid())
  userId      String
  leagueId    String?
  type        FeedbackType
  body        String         @db.Text
  url         String?
  status      FeedbackStatus @default(OPEN)
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id])
  league      FantasyLeague? @relation(fields: [leagueId], references: [id])
  backlogItem BacklogItem?

  @@index([createdAt])
}

model BacklogItem {
  id         String              @id @default(cuid())
  feedbackId String?             @unique
  title      String
  userStory  String              @db.Text
  priority   String              @default("P2")
  category   String              @default("FEATURE")
  createdAt  DateTime            @default(now())
  feedback   FeedbackSubmission? @relation(fields: [feedbackId], references: [id])
}

enum FeedbackType {
  BUG
  SUGGESTION
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_BACKLOG
  RESOLVED
  DISMISSED
}

enum BetaStatus {
  NONE
  INVITED
  ACCEPTED
  ACTIVE
  RENEWED
}

enum EventType {
  DRAFT_PICK
  PLAYER_ADD
  PLAYER_DROP
  TRADE
  PLAYOFF_QUALIFICATION
  PLAYOFF_CLINCH
  PLAYOFF_ELIMINATION
  CHAMPIONSHIP_WON
  MAJOR_PERFORMANCE
  COMMISSIONER_FORCE_MOVE
  COMMISSIONER_UNDO_TRANSACTION
  COMMISSIONER_REPLACE_MANAGER
  COMMISSIONER_DRAFT_PAUSED
  COMMISSIONER_DRAFT_RESUMED
  COMMISSIONER_ANNOUNCEMENT
  COMMISSIONER_SETTINGS_CHANGED
  WAIVER_CLAIM_SUBMITTED
  WAIVER_CLAIM_AWARDED
  WAIVER_CLAIM_DENIED
  WAIVER_CLAIM_CANCELLED
  LEAGUE_STORYLINE
}

enum WaiverStatus {
  PENDING
  AWARDED
  DENIED
  CANCELLED
}

model WaiverEntry {
  id        String        @id @default(cuid())
  leagueId  String
  playerId  String
  expiresAt DateTime
  createdAt DateTime      @default(now())
  league    FantasyLeague @relation(fields: [leagueId], references: [id])
  player    Player        @relation(fields: [playerId], references: [id])

  @@unique([leagueId, playerId])
  @@index([leagueId, expiresAt])
}

model WaiverClaim {
  id               String        @id @default(cuid())
  leagueId         String
  fantasyTeamId    String
  addPlayerId      String
  dropPlayerId     String?
  prioritySnapshot Int
  status           WaiverStatus  @default(PENDING)
  processedAt      DateTime?
  createdAt        DateTime      @default(now())
  league           FantasyLeague @relation(fields: [leagueId], references: [id])
  fantasyTeam      FantasyTeam   @relation(fields: [fantasyTeamId], references: [id])

  @@unique([leagueId, fantasyTeamId, addPlayerId])
  @@index([leagueId, status, addPlayerId])
}

model WaiverPriority {
  leagueId      String
  fantasyTeamId String
  priority      Int
  updatedAt     DateTime      @default(now()) @updatedAt
  league        FantasyLeague @relation(fields: [leagueId], references: [id])
  fantasyTeam   FantasyTeam   @relation(fields: [fantasyTeamId], references: [id])

  @@id([leagueId, fantasyTeamId])
  @@unique([leagueId, priority])
}
