# Database
DATABASE_URL=postgresql://...

# Auth cookie domain (set to ".dykedb.org" in production)
COOKIE_DOMAIN=

# PostHog analytics
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Draft WebSocket server
NEXT_PUBLIC_DRAFT_WS_URL=ws://localhost:8080

# Dev / staging controls
ALLOW_SIM_DATE=true

# Beta lockdown (set to the production hostname to restrict it)
BETA_HOST=
BETA_SITE_HOST=

# Founder console (comma-separated email list)
FOUNDER_EMAILS=

# Cron auth secret
CRON_SECRET=
