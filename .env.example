# Copy to .env and fill in. Never commit .env.

# ─── Database ───────────────────────────────────────────────────────────────

# Connection string for normal queries (using pooler in Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/pwhl_fantasy?schema=public"

# Direct connection for migrations (non-pooled, bypasses pgBouncer)
# Required for Prisma migrate deploy. In Neon, use the direct connection endpoint.
DIRECT_URL="postgresql://user:password@localhost:5432/pwhl_fantasy?schema=public"

# ─── Auth & Security ────────────────────────────────────────────────────────

# Auth provider secrets (if using an auth provider rather than rolling your own)
AUTH_SECRET=""

# Cron job verification secret. Used to authenticate requests to /api/cron/* routes.
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Stats Source (Data Ingestion) ──────────────────────────────────────────

# HockeyTech/LeagueStat API config (for ingest scripts — leave blank until configured)
STATS_SOURCE_BASE_URL="https://lscluster.hockeytech.com/feed/index.php"
STATS_SOURCE_API_KEY="446521baf8c38984"

# ─── Feature Flags ──────────────────────────────────────────────────────────

# Enable beta mode features (wizard welcome screen, beta-specific UI)
# Set on Vercel pwhl-gm-beta project only, not on production
NEXT_PUBLIC_BETA_MODE="false"

# ─── WebSocket & Real-Time ──────────────────────────────────────────────────

# Draft room WebSocket server URL. Defaults to localhost:8080 for local dev.
NEXT_PUBLIC_DRAFT_WS_URL="ws://localhost:8080"

# ─── Admin & Monitoring ─────────────────────────────────────────────────────

# Founder Operations Console — comma-separated list of emails with founder access
# Add your login email here to access /founder admin panel (league explorer, sim controls, etc.)
FOUNDER_EMAILS=""

# Dev mode: Allow season advance via API (set to true in dev only)
ALLOW_SEASON_ADVANCE="false"

# Dev mode: Allow sim date overrides via cookie (set to true in dev only)
ALLOW_SIM_DATE="false"

# ─── Email (Resend) ──────────────────────────────────────────────────────────

# Get your API key at resend.com. Set in Vercel env vars for production.
RESEND_API_KEY=""

# "From" address used in all outgoing emails. Requires domain verification in Resend
# (DKIM TXT + SPF records for dykedb.org — one-time DNS setup).
EMAIL_FROM="PWHL GM <noreply@dykedb.org>"

# Master switch for real email delivery.
# Set to "true" in Production only. Leave unset/false on staging to prevent real emails.
# The draft WebSocket server on Render also needs this env var set.
EMAIL_RESEND_ENABLED="false"

# Base URL used when constructing magic link and notification URLs in emails.
NEXT_PUBLIC_APP_URL="https://beta.fantasy.dykedb.org"
