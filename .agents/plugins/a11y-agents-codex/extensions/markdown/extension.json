{
  "name": "accessibility-agents-markdown",
  "displayName": "Markdown Accessibility Extension",
  "version": "6.0.0",
  "builtIn": true,
  "description": "Built-in markdown accessibility specialists for docs, headings, links, alt text, reports, and markdown remediation.",
  "domains": [
    "markdown",
    "documents"
  ],
  "extensionPoints": [
    "agents",
    "references",
    "rules",
    "complianceProfiles"
  ],
  "complianceProfiles": [
    "wcag-2.2-aa"
  ],
  "agents": [
    {
      "name": "markdown-a11y-assistant",
      "domains": [
        "documents"
      ],
      "path": "../../agents/markdown-a11y-assistant.toml",
      "reference": "../../references/specialists/markdown-a11y-assistant.md"
    },
    {
      "name": "markdown-scanner",
      "domains": [
        "documents"
      ],
      "path": "../../agents/markdown-scanner.toml",
      "reference": "../../references/specialists/markdown-scanner.md"
    },
    {
      "name": "markdown-fixer",
      "domains": [
        "documents"
      ],
      "path": "../../agents/markdown-fixer.toml",
      "reference": "../../references/specialists/markdown-fixer.md"
    },
    {
      "name": "markdown-csv-reporter",
      "domains": [
        "documents"
      ],
      "path": "../../agents/markdown-csv-reporter.toml",
      "reference": "../../references/specialists/markdown-csv-reporter.md"
    }
  ],
  "author": "Community Access"
}
